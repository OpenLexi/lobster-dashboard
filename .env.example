# Lobster Dashboard Environment Variables
# Copy this file to .env and fill in your values

# Security
SECRET_KEY=change-me-in-production
ADMIN_PASSWORD_HASH=  # Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"

# Database
# Local dev (SQLite)
# DATABASE_URL=sqlite:///./lobster.db
# Production (Postgres example)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# Agent
AGENT_NAME=Lobster
AGENT_EMAIL=agent@lobster.local

# Budget
MONTHLY_BUDGET_USD=500

# Environment
ENV=development